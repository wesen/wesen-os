    31	  launch: AppManifestLaunchConfig;
    32	  backend?: AppManifestBackendConfig;
    33	  desktop?: AppManifestDesktopIconConfig;
    34	}
    35	
    36	const APP_ID_RE = /^[a-z][a-z0-9-]*$/;
    37	const APP_STATE_KEY_RE = /^app_[a-z0-9_]+$/;
    38	
    39	function invariant(condition: boolean, message: string): asserts condition {
    40	  if (!condition) {
    41	    throw new Error(message);
    42	  }
    43	}
    44	
    45	export function assertValidAppId(appId: string): void {
    46	  invariant(APP_ID_RE.test(appId), `Invalid app id "${appId}". Expected /^[a-z][a-z0-9-]*$/.`);
    47	}
    48	
    49	export function assertValidStateKey(stateKey: string): asserts stateKey is AppStateKey {
    50	  invariant(APP_STATE_KEY_RE.test(stateKey), `Invalid app state key "${stateKey}". Expected /^app_[a-z0-9_]+$/.`);
    51	}
    52	
    53	export function assertValidManifest(manifest: AppManifest): void {
    54	  assertValidAppId(manifest.id);
    55	  invariant(manifest.name.trim().length > 0, `Invalid app manifest for "${manifest.id}": name is required.`);
    56	  invariant(manifest.icon.trim().length > 0, `Invalid app manifest for "${manifest.id}": icon is required.`);
    57	  if (manifest.desktop?.id) {
    58	    invariant(
    59	      manifest.desktop.id.trim().length > 0,
    60	      `Invalid app manifest for "${manifest.id}": desktop.id cannot be blank.`,
    61	    );
    62	  }
    63	}
    64	
    65	export function assertUniqueManifestIds(manifests: readonly AppManifest[]): void {
    66	  const seen = new Set<string>();
    67	  for (const manifest of manifests) {
    68	    assertValidManifest(manifest);
    69	    if (seen.has(manifest.id)) {
    70	      throw new Error(`Duplicate app manifest id "${manifest.id}".`);
    71	    }
    72	    seen.add(manifest.id);
    73	  }
    74	}
    75	
    76	export function assertUniqueStateKeys(stateKeys: readonly string[]): void {
    77	  const seen = new Set<string>();
    78	  for (const stateKey of stateKeys) {
    79	    assertValidStateKey(stateKey);
    80	    if (seen.has(stateKey)) {
    81	      throw new Error(`Duplicate app state key "${stateKey}".`);
    82	    }
    83	    seen.add(stateKey);
    84	  }
    85	}

