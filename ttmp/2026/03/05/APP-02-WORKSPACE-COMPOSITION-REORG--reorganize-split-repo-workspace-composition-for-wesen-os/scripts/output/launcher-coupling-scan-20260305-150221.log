     1	import { type AppManifest, assertUniqueManifestIds, assertUniqueStateKeys } from '../contracts/appManifest';
     2	import type { LaunchableAppModule } from '../contracts/launchableAppModule';
     3	
     4	export interface AppRegistry {
     5	  get: (appId: string) => LaunchableAppModule | undefined;
     6	  has: (appId: string) => boolean;
     7	  list: () => readonly LaunchableAppModule[];
     8	  listManifests: () => readonly AppManifest[];
     9	}
    10	
    11	function sortModules(modules: readonly LaunchableAppModule[]): LaunchableAppModule[] {
    12	  return [...modules].sort((a, b) => {
    13	    const leftOrder = a.manifest.desktop?.order ?? Number.MAX_SAFE_INTEGER;
    14	    const rightOrder = b.manifest.desktop?.order ?? Number.MAX_SAFE_INTEGER;
    15	    if (leftOrder !== rightOrder) {
    16	      return leftOrder - rightOrder;
    17	    }
    18	    return a.manifest.id.localeCompare(b.manifest.id);
    19	  });
    20	}
    21	
    22	export function createAppRegistry(modules: readonly LaunchableAppModule[]): AppRegistry {
    23	  const orderedModules = sortModules(modules);
    24	  const manifests = orderedModules.map((module) => module.manifest);
    25	  assertUniqueManifestIds(manifests);
    26	  const stateKeys = orderedModules.flatMap((module) => (module.state ? [module.state.stateKey] : []));
    27	  assertUniqueStateKeys(stateKeys);
    28	
    29	  const moduleMap = new Map<string, LaunchableAppModule>();
    30	  for (const module of orderedModules) {
    31	    if (moduleMap.has(module.manifest.id)) {
    32	      throw new Error(`Duplicate app module id "${module.manifest.id}".`);
    33	    }
    34	    moduleMap.set(module.manifest.id, module);
    35	  }
    36	
    37	  return {
    38	    get: (appId) => moduleMap.get(appId),
    39	    has: (appId) => moduleMap.has(appId),
    40	    list: () => orderedModules,
    41	    listManifests: () => manifests,
    42	  };
    43	}

     1	import { type CreateAppStoreOptions, createAppStore } from '@hypercard/hypercard-runtime';
     2	import type { Reducer } from '@reduxjs/toolkit';
     3	import type { AppStateKey } from '../contracts/appManifest';
     4	import type { LaunchableAppModule } from '../contracts/launchableAppModule';
     5	
     6	const ENGINE_CORE_REDUCER_KEYS = new Set([
     7	  'pluginCardRuntime',
     8	  'windowing',
     9	  'notifications',
    10	  'debug',
    11	  'hypercardArtifacts',
    12	]);
    13	
    14	export function collectModuleReducers(modules: readonly LaunchableAppModule[]): Record<string, Reducer> {
    15	  const seen = new Set<string>();
    16	  const reducers: Record<string, Reducer> = {};
    17	
    18	  for (const module of modules) {
    19	    if (!module.state) {
    20	      continue;
    21	    }
    22	
    23	    const { stateKey, reducer } = module.state;
    24	    if (ENGINE_CORE_REDUCER_KEYS.has(stateKey)) {
    25	      throw new Error(`App module "${module.manifest.id}" uses reserved reducer key "${stateKey}".`);
    26	    }
    27	    if (seen.has(stateKey)) {
    28	      throw new Error(`Duplicate app reducer key "${stateKey}".`);
    29	    }
    30	
    31	    seen.add(stateKey);
    32	    reducers[stateKey] = reducer;
    33	  }
    34	
    35	  return reducers;
    36	}
    37	
    38	export interface CreateLauncherStoreOptions extends CreateAppStoreOptions {
    39	  sharedReducers?: Record<string, Reducer>;
    40	}
    41	
    42	function assertValidReducerKey(key: string, seen: Set<string>): void {
    43	  if (ENGINE_CORE_REDUCER_KEYS.has(key)) {
    44	    throw new Error(`Launcher store reducer key "${key}" is reserved by engine core reducers.`);
    45	  }
    46	  if (seen.has(key)) {
    47	    throw new Error(`Duplicate launcher reducer key "${key}".`);
    48	  }
    49	  seen.add(key);
    50	}
    51	
    52	function mergeLauncherReducers(
    53	  moduleReducers: Record<string, Reducer>,
    54	  sharedReducers: Record<string, Reducer>,
    55	): Record<string, Reducer> {
    56	  const merged: Record<string, Reducer> = {};
    57	  const seen = new Set<string>();
    58	
    59	  for (const [key, reducer] of Object.entries(sharedReducers)) {
    60	    assertValidReducerKey(key, seen);
    61	    merged[key] = reducer;
    62	  }
    63	  for (const [key, reducer] of Object.entries(moduleReducers)) {
    64	    assertValidReducerKey(key, seen);
    65	    merged[key] = reducer;
    66	  }
    67	
    68	  return merged;
    69	}
    70	
    71	export function createLauncherStore(modules: readonly LaunchableAppModule[], options: CreateLauncherStoreOptions = {}) {
    72	  const { sharedReducers = {}, ...storeOptions } = options;
    73	  const moduleReducers = collectModuleReducers(modules);
    74	  const reducers = mergeLauncherReducers(moduleReducers, sharedReducers);
    75	  return createAppStore(reducers, storeOptions);
    76	}
    77	
    78	export function selectModuleState<TSlice = unknown>(state: unknown, stateKey: AppStateKey): TSlice | undefined {
    79	  if (typeof state !== 'object' || state === null || Array.isArray(state)) {
    80	    return undefined;
    81	  }
    82	  return (state as Record<string, unknown>)[stateKey] as TSlice | undefined;
    83	}
    84	
    85	export function createModuleSelector<TSlice = unknown, TResult = TSlice | undefined>(
    86	  stateKey: AppStateKey,
    87	  selector: (slice: TSlice | undefined) => TResult,
    88	) {
    89	  return (state: unknown): TResult => selector(selectModuleState<TSlice>(state, stateKey));
    90	}

