     3	import (
     4		"encoding/json"
     5		"net/http"
     6		"strings"
     7	)
     8	
     9	type AppManifestDocument struct {
    10		AppID        string                     `json:"app_id"`
    11		Name         string                     `json:"name"`
    12		Description  string                     `json:"description,omitempty"`
    13		Required     bool                       `json:"required"`
    14		Capabilities []string                   `json:"capabilities,omitempty"`
    15		Reflection   *AppManifestReflectionHint `json:"reflection,omitempty"`
    16		Docs         *AppManifestDocsHint       `json:"docs,omitempty"`
    17		Healthy      bool                       `json:"healthy"`
    18		HealthError  string                     `json:"health_error,omitempty"`
    19	}
    20	
    21	type AppManifestReflectionHint struct {
    22		Available bool   `json:"available"`
    23		URL       string `json:"url,omitempty"`
    24		Version   string `json:"version,omitempty"`
    25	}
    26	
    27	type AppManifestDocsHint struct {
    28		Available bool   `json:"available"`
    29		URL       string `json:"url,omitempty"`
    30		Count     int    `json:"count,omitempty"`
    31		Version   string `json:"version,omitempty"`
    32	}
    33	
    34	type AppManifestResponse struct {
    35		Apps []AppManifestDocument `json:"apps"`
    36	}
    37	
    38	func RegisterAppsManifestEndpoint(mux *http.ServeMux, registry *ModuleRegistry) {
    39		if mux == nil || registry == nil {
    40			return
    41		}
    42	
    43		mux.HandleFunc("/api/os/apps", func(w http.ResponseWriter, req *http.Request) {
    44			if req.Method != http.MethodGet {
    45				http.Error(w, "method not allowed", http.StatusMethodNotAllowed)
    46				return
    47			}
    48	
    49			response := AppManifestResponse{Apps: make([]AppManifestDocument, 0, len(registry.Modules()))}
    50			for _, module := range registry.Modules() {
    51				manifest := module.Manifest()
    52				healthErr := module.Health(req.Context())
    53				doc := AppManifestDocument{
    54					AppID:        strings.TrimSpace(manifest.AppID),
    55					Name:         strings.TrimSpace(manifest.Name),
    56					Description:  strings.TrimSpace(manifest.Description),
    57					Required:     manifest.Required,
    58					Capabilities: append([]string(nil), manifest.Capabilities...),
    59					Healthy:      healthErr == nil,
    60				}
    61				if _, ok := module.(ReflectiveAppBackendModule); ok {
    62					doc.Reflection = &AppManifestReflectionHint{
    63						Available: true,
    64						URL:       "/api/os/apps/" + doc.AppID + "/reflection",
    65						Version:   "v1",
    66					}
    67				}
    68				if documentable, ok := module.(DocumentableAppBackendModule); ok {
    69					if store := documentable.DocStore(); store != nil {
    70						doc.Docs = &AppManifestDocsHint{
    71							Available: true,
    72							URL:       "/api/apps/" + doc.AppID + "/docs",
    73							Count:     store.Count(),
    74							Version:   "v1",
    75						}
    76					}
    77				}
    78				if healthErr != nil {
    79					doc.HealthError = healthErr.Error()
    80				}
    81				response.Apps = append(response.Apps, doc)
    82			}
    83	
    84			w.Header().Set("Content-Type", "application/json")
    85			_ = json.NewEncoder(w).Encode(response)
    86		})
    87	
    88		mux.HandleFunc("/api/os/apps/", func(w http.ResponseWriter, req *http.Request) {
    89			if req.Method != http.MethodGet {
    90				http.Error(w, "method not allowed", http.StatusMethodNotAllowed)
    91				return
    92			}
    93	
    94			appID, ok := parseReflectionPath(req.URL.Path)
    95			if !ok {
    96				http.NotFound(w, req)
    97				return
    98			}
    99	
   100			module, exists := registry.Get(appID)
   101			if !exists {
   102				http.NotFound(w, req)
   103				return
   104			}
   105			reflective, ok := module.(ReflectiveAppBackendModule)
   106			if !ok {
   107				http.Error(w, "reflection not implemented", http.StatusNotImplemented)
   108				return
   109			}
   110	
   111			reflection, err := reflective.Reflection(req.Context())
   112			if err != nil {
   113				http.Error(w, err.Error(), http.StatusInternalServerError)
   114				return
   115			}
   116			if reflection == nil {
   117				http.Error(w, "reflection document is nil", http.StatusInternalServerError)
   118				return
   119			}
   120	
   121			w.Header().Set("Content-Type", "application/json")
   122			_ = json.NewEncoder(w).Encode(reflection)
   123		})
   124	}
   125	
   126	func parseReflectionPath(path string) (string, bool) {
   127		trimmed := strings.TrimPrefix(path, "/api/os/apps/")
   128		trimmed = strings.Trim(trimmed, "/")
   129		if trimmed == "" {
   130			return "", false
   131		}
   132		parts := strings.Split(trimmed, "/")
   133		if len(parts) != 2 || parts[1] != "reflection" {
   134			return "", false
   135		}
   136		appID := strings.TrimSpace(parts[0])
   137		if appID == "" {
   138			return "", false
   139		}
   140		return appID, true
   141	}

## composition mount in wesen-os
   314		moduleRegistry, err := backendhost.NewModuleRegistry(modules...)
   315		if err != nil {
   316			return errors.Wrap(err, "create backend module registry")
