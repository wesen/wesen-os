   318		if err := backendhost.GuardNoLegacyAliases(parseCSV(cfg.LegacyAliases)); err != nil {
   319			return errors.Wrap(err, "validate legacy route aliases")
   320		}
   321		lifecycle := backendhost.NewLifecycleManager(moduleRegistry)
