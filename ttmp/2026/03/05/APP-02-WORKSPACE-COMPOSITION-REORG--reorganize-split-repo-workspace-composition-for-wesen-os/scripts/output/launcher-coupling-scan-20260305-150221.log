   323			RequiredAppIDs: parseCSV(cfg.RequiredApps),
   324		}); err != nil {
   325			return errors.Wrap(err, "start backend module lifecycle")
   326		}
   327		defer func() { _ = lifecycle.Stop(context.Background()) }()
   328	
