{
  "name": "wesen-os-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "workspace-links/*/packages/*",
    "workspace-links/*/apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/os-launcher",
    "build": "npm run build -w apps/os-launcher",
    "test": "npm run test -w apps/os-launcher",
    "typecheck": "node ./node_modules/typescript/bin/tsc --build",
    "launcher:frontend:build": "npm run build -w apps/os-launcher",
    "launcher:ui:sync": "bash ./scripts/launcher-ui-sync.sh",
    "launcher:binary:build": "npm run launcher:frontend:build && npm run launcher:ui:sync && bash ./scripts/build-wesen-os-launcher.sh",
    "launcher:smoke": "bash ./scripts/smoke-wesen-os-launcher.sh",
    "launcher:dev:start": "bash ./scripts/launcher-dev-tmux.sh start",
    "launcher:dev:restart": "bash ./scripts/launcher-dev-tmux.sh restart",
    "launcher:dev:stop": "bash ./scripts/launcher-dev-tmux.sh stop",
    "launcher:dev:status": "bash ./scripts/launcher-dev-tmux.sh status",
    "launcher:dev:attach": "bash ./scripts/launcher-dev-tmux.sh attach",
    "workspace:init-submodules": "bash ./scripts/init-submodules.sh",
    "workspace:setup": "bash ./scripts/setup-workspace.sh",
    "workspace:test": "bash ./scripts/test-workspace.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "typescript": "~5.7.0",
    "vitest": "^4.0.18"
  }
}
