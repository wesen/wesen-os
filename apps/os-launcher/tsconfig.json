{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "dist",
    "paths": {
      "@hypercard/repl": [
        "../../workspace-links/go-go-os-frontend/packages/repl/src/index.ts"
      ],
      "@hypercard/repl/*": [
        "../../workspace-links/go-go-os-frontend/packages/repl/src/*"
      ],
      "@hypercard/arc-agi-player/launcher": [
        "../../workspace-links/go-go-app-arc-agi-3/apps/arc-agi-player/src/launcher/public.ts",
        "./src/app/shims/arcAgiPlayerLauncher.ts"
      ],
      "@hypercard/sqlite/launcher": [
        "../../workspace-links/go-go-app-sqlite/apps/sqlite/src/launcher/public.ts",
        "./src/app/shims/sqliteLauncher.ts"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/__tests__"]
}
