      "@go-go-golems/os-core": ["./node_modules/@go-go-golems/os-core"],
      "@go-go-golems/os-core/*": ["./node_modules/@go-go-golems/os-core/*"],
      "@go-go-golems/os-core/desktop-core": ["./node_modules/@go-go-golems/os-core/src/desktop-core.ts"],
      "@go-go-golems/os-core/desktop-react": ["./node_modules/@go-go-golems/os-core/src/desktop-react.ts"],
      "@go-go-golems/os-kanban": ["./node_modules/@go-go-golems/os-kanban"],
