      "@go-go-golems/os-scripting/*": ["./node_modules/@go-go-golems/os-scripting/*"],
      "@go-go-golems/os-shell": ["./node_modules/@go-go-golems/os-shell"],
      "@go-go-golems/os-shell/*": ["./node_modules/@go-go-golems/os-shell/*"],
      "@go-go-golems/os-ui-cards": ["./node_modules/@go-go-golems/os-ui-cards"],
      "@go-go-golems/os-ui-cards/*": ["./node_modules/@go-go-golems/os-ui-cards/*"],
      "@go-go-golems/os-widgets": ["./node_modules/@go-go-golems/os-widgets"],
