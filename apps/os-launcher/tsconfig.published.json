      "@go-go-golems/arc-agi-player/launcher": [
        "../../workspace-links/go-go-app-arc-agi-3/apps/arc-agi-player/src/launcher/public.ts",
        "./src/app/shims/arcAgiPlayerLauncher.ts"
      ],
      "@go-go-golems/sqlite/launcher": [
        "../../workspace-links/go-go-app-sqlite/apps/sqlite/src/launcher/public.ts",
        "./src/app/shims/sqliteLauncher.ts"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/__tests__"]
